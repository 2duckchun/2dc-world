{
  "name": "2dc-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "spellcheck": "cspell lint . --no-progress",
    "lint:staged": "lint-staged",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,jsonc,css}": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,jsonc,css,md,mdx,txt,yml,yaml}": [
      "cspell lint --no-summary --no-progress --no-must-find-files"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cspell": "9.2.1",
    "husky": "9.1.7",
    "lint-staged": "16.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
