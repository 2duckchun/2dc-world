{
  "name": "2dc-world",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "biome check",
    "format": "biome format --write",
    "spellcheck": "cspell lint . --no-progress",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,jsonc,css}": [
      "biome check --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,jsonc,css,md,mdx,txt,yml,yaml}": [
      "cspell lint --no-summary --no-progress --no-must-find-files"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@base-ui/react": "^1.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@mdxeditor/editor": "^3.55.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.100.5",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cspell": "9.2.1",
    "drizzle-kit": "^0.31.10",
    "husky": "9.1.7",
    "lint-staged": "16.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
